source "https://rubygems.org"

# This gem includes Jekyll and the default plugins supported by GitHub Pages
gem "github-pages", group: :jekyll

# The Modernist theme
gem "jekyll-theme-modernist"

# SEO and Indexing Plugins
group :jekyll_plugins do
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
  gem "jekyll-feed"
  gem "jekyll-gist"
  gem "jekyll-include-cache"
end

# Windows users might need this, adding it for cross-platform compatibility
gem "webrick", "~> 1.7"
